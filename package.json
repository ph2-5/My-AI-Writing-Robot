{
  "name": "ai-writing-robot",
  "private": true,
  "version": "1.0.0",
  "description": "AI写字机器人 - 智能作业生成与机器人控制",
  "author": "AI Writing Robot Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run client:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:pack": "npm run build && npx electron-packager . \"AI写字机器人\" --platform=win32 --arch=x64 --out=release --overwrite --no-asar && xcopy /E /I /Y dist \"release\\AI写字机器人-win32-x64\\resources\\app\\dist\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.aiwritingrobot.app",
    "productName": "AI写字机器人",
    "directories": {
      "output": "release-build",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "./",
        "to": ".",
        "filter": [
          "main.py",
          "config.py",
          "logging_utils.py",
          "requirements.txt",
          "analyzers/**",
          "effects/**",
          "fonts/**",
          "layout/**",
          "output/**",
          "parsers/**",
          "scripts/**"
        ]
      },
      {
        "from": "electron/server.py",
        "to": "electron/server.py"
      }
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "artifactName": "AI写字机器人-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI写字机器人",
      "installerLanguages": [
        "zh-CN"
      ],
      "language": 2052,
      "artifactName": "AI写字机器人-Setup-${version}-${arch}.${ext}"
    }
  }
}
